<!DOCTYPE html>
<html lang="ko">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>회사 경비 관리</title>

<style>
body{
    font-family: Arial, sans-serif;
    background:#f4f6f9;
    margin:0;
    padding:20px;
}

.container{
    max-width:700px;
    margin:auto;
}

.card{
    background:white;
    padding:20px;
    margin-bottom:15px;
    border-radius:10px;
    box-shadow:0 2px 5px rgba(0,0,0,0.1);
}

h1{
    text-align:center;
}

input,button{
    width:100%;
    padding:10px;
    margin-top:8px;
    border:1px solid #ccc;
    border-radius:5px;
    box-sizing:border-box;
}

button{
    background:#007bff;
    color:white;
    border:none;
    cursor:pointer;
}

button:hover{
    background:#0056b3;
}

table{
    width:100%;
    border-collapse:collapse;
}

th,td{
    border-bottom:1px solid #ddd;
    padding:8px;
    text-align:center;
}

.summary{
    font-size:18px;
    font-weight:bold;
    line-height:1.8;
}

.delete-btn{
    background:red;
    padding:5px 10px;
}
</style>
</head>

<body>

<div class="container">

<h1>회사 경비 관리</h1>

<div class="card">
<h3>예산 설정</h3>

<label>월 예산 (USD)</label>
<input type="number" id="budget" value="350">

<label>환율 (1 USD = ? VND)</label>
<input type="number" id="rate" value="26000">

<button onclick="saveSettings()">설정 저장</button>
</div>

<div class="card">
<h3>경비 입력</h3>

<input type="text" id="desc" placeholder="사용 내역">

<input type="number" id="amount"
placeholder="사용 금액(VND)">

<button onclick="addExpense()">추가</button>
</div>

<div class="card">
<h3>예산 현황</h3>

<div class="summary">
총 예산(VND):
<span id="budgetVND"></span><br>

사용 금액(VND):
<span id="usedVND"></span><br>

잔액(VND):
<span id="remainVND"></span><br>

잔액(USD):
<span id="remainUSD"></span>
</div>
</div>

<div class="card">
<h3>사용 내역</h3>

<table>
<thead>
<tr>
<th>내역</th>
<th>금액(VND)</th>
<th>삭제</th>
</tr>
</thead>
<tbody id="expenseTable"></tbody>
</table>
</div>

</div>

<script>

let expenses =
JSON.parse(localStorage.getItem("expenses")) || [];

function saveSettings(){
    localStorage.setItem(
        "budget",
        document.getElementById("budget").value
    );

    localStorage.setItem(
        "rate",
        document.getElementById("rate").value
    );

    updateSummary();
}

function loadSettings(){

    document.getElementById("budget").value =
        localStorage.getItem("budget") || 350;

    document.getElementById("rate").value =
        localStorage.getItem("rate") || 26000;
}

function addExpense(){

    let desc =
    document.getElementById("desc").value;

    let amount =
    Number(document.getElementById("amount").value);

    if(!desc || amount<=0){
        alert("사용 내역과 금액을 입력하세요.");
        return;
    }

    expenses.push({
        desc,
        amount
    });

    saveExpenses();

    document.getElementById("desc").value="";
    document.getElementById("amount").value="";

    renderTable();
}

function saveExpenses(){
    localStorage.setItem(
        "expenses",
        JSON.stringify(expenses)
    );
}

function deleteExpense(index){

    if(confirm("삭제하시겠습니까?")){
        expenses.splice(index,1);
        saveExpenses();
        renderTable();
    }
}

function renderTable(){

    let tbody =
    document.getElementById("expenseTable");

    tbody.innerHTML="";

    expenses.forEach((item,index)=>{

        tbody.innerHTML += `
        <tr>
            <td>${item.desc}</td>
            <td>${item.amount.toLocaleString()}</td>
            <td>
                <button class="delete-btn"
                onclick="deleteExpense(${index})">
                삭제
                </button>
            </td>
        </tr>
        `;
    });

    updateSummary();
}

function updateSummary(){

    let budget =
    Number(document.getElementById("budget").value);

    let rate =
    Number(document.getElementById("rate").value);

    let budgetVND =
    budget * rate;

    let used =
    expenses.reduce(
        (sum,e)=>sum+e.amount,0
    );

    let remain =
    budgetVND - used;

    document.getElementById("budgetVND").innerText =
    budgetVND.toLocaleString();

    document.getElementById("usedVND").innerText =
    used.toLocaleString();

    document.getElementById("remainVND").innerText =
    remain.toLocaleString();

    document.getElementById("remainUSD").innerText =
    (remain/rate).toFixed(2);
}

loadSettings();
renderTable();

</script>

</body>
</html>
